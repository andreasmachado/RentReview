{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/client/*"],
      "@shared/*": ["./src/server/lib/*"]
    },
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "vitest.config.ts",
    "tailwind.config.ts",
    "drizzle.config.ts"
  ]
}
